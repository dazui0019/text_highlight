{
  "manifest_version": 3,
  "name": "Text Highlight",
  "version": "1.0.0",
  "description": "Highlight specific strings on webpages.",
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Text Highlight"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
