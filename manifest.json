{
  "manifest_version": 3,
  "name": "Polarion Step Assistant",
  "version": "1.0.0",
  "description": "Navigate Polarion steps and inspect changed signals.",
  "permissions": ["storage"],
  "host_permissions": ["*://*/polarion*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Polarion Step Assistant"
  },
  "content_scripts": [
    {
      "matches": ["*://*/polarion*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
